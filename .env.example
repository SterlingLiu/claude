# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=lostfound

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=请修改为随机字符串
JWT_EXPIRES_IN=7d

# 文件上传
UPLOAD_DIR=uploads

# 服务端口
PORT=3000

# CORS 允许的来源（逗号分隔），留空则默认允许 localhost:5173 和 localhost:3000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# 最大文件大小（字节）
MAX_FILE_SIZE=5242880
