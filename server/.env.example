# ============================================
# 校园失物招领平台 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================

# ---- 服务配置 ----
PORT=3000
NODE_ENV=development

# ---- 数据库配置 ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lostfound
DB_CONNECTION_LIMIT=20

# ---- JWT 认证配置 ----
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# ---- 跨域配置 (可选，逗号分隔多个域名) ----
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ---- 文件上传配置 ----
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ---- 日志配置 (可选) ----
# LOG_LEVEL=info
